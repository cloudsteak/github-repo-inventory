# GitHub fine-grained personal access token (PAT).
# Create at: https://github.com/settings/personal-access-tokens
# Permission checklist: docs/authentication.md
GITHUB_TOKEN=github_pat_your_token_here

# Optional: local dev/preview password (npm run dev). Not used for GitHub Pages —
# Pages encryption uses the DASHBOARD_PASSWORD repository secret in Actions only.
DASHBOARD_PASSWORD=change-me
